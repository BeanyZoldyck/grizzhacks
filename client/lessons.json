          "width": 150,
          "height": 30,
          "font_size": 16,
          "color": "255,255,255"
        },
        {
          "type": "Text",
          "text": "GPIO2 \u2192",
          "x": 400,
          "y": 200,
          "width": 120,
          "height": 30,
          "font_size": 16,
          "color": "0,255,100"
        },
        {
          "type": "Line",
          "x": 520,
          "y": 215,
          "width": 30,
          "height": 0,
          "color": "255,0,0"
        },
        {
          "type": "Graphics",
