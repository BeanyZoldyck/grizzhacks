{
  "lesson_name": "Wiring_an_LED_with_ESP32-C3",
  "description": "Learn how to safely wire an LED to an ESP32-C3 microcontroller using a current-limiting resistor",
  "steps": [
    {
      "step": 1,
      "description": "Gather required components",
      "instruction": "Collect the following components: ESP32-C3 development board, one LED (any color), one 330\u03a9 resistor (or similar), and two jumper wires. Verify the LED polarity - the longer lead is the anode (positive) and the shorter lead is the cathode (negative).",
      "visuals": [
        {
          "type": "Text",
          "text": "Components Needed:",
          "x": 50,
          "y": 50,
          "width": 300,
          "height": 40,
          "font_size": 24,
          "color": "0,200,255"
        },
        {
          "type": "Text",
          "text": "\u2022 ESP32-C3 Dev Board",
          "x": 50,
          "y": 120,
          "width": 300,
          "height": 30,
          "font_size": 18,
          "color": "255,255,255"
        },
        {
          "type": "Text",
          "text": "\u2022 1x LED (any color)",
          "x": 50,
          "y": 160,
          "width": 300,
          "height": 30,
          "font_size": 18,
          "color": "255,255,255"
        },
        {
          "type": "Text",
          "text": "\u2022 1x 330\u03a9 Resistor",
          "x": 50,
          "y": 200,
          "width": 300,
          "height": 30,
          "font_size": 18,
          "color": "255,255,255"
        },
        {
          "type": "Text",
          "text": "\u2022 2x Jumper Wires",
          "x": 50,
          "y": 240,
          "width": 300,
          "height": 30,
          "font_size": 18,
          "color": "255,255,255"
        },
        {
          "type": "Graphics",
          "filename": "led_symbol.svg",
          "x": 600,
          "y": 150,
          "width": 100,
          "height": 100,
          "color": "255,0,0"
        },
        {
          "type": "Text",
          "text": "Anode (+) - Longer lead",
          "x": 550,
          "y": 270,
          "width": 200,
          "height": 25,
          "font_size": 14,
          "color": "255,200,0"
        },
        {
          "type": "Text",
          "text": "Cathode (-) - Shorter lead",
          "x": 550,
          "y": 295,
          "width": 200,
          "height": 25,
          "font_size": 14,
          "color": "150,150,150"
        }
      ]
    },
    {
      "step": 2,
      "description": "Connect resistor to LED anode",
      "instruction": "Insert one lead of the 330\u03a9 resistor into the same row as the LED's anode (longer lead). Bend the resistor leads to secure the connection. This resistor limits current flow to protect the LED from burning out.",
      "visuals": [
        {
          "type": "Text",
          "text": "Step 2: Add Current-Limiting Resistor",
          "x": 50,
          "y": 50,
          "width": 500,
          "height": 40,
          "font_size": 22,
          "color": "0,200,255"
        },
        {
          "type": "Graphics",
          "filename": "breadboard.svg",
          "x": 200,
          "y": 150,
          "width": 400,
          "height": 300,
          "color": "50,50,80"
        },
        {
          "type": "Graphics",
          "filename": "led_component.svg",
          "x": 350,
          "y": 220,
          "width": 80,
          "height": 60,
          "color": "255,0,0"
        },
        {
          "type": "Graphics",
          "filename": "resistor_component.svg",
          "x": 250,
          "y": 220,
          "width": 80,
          "height": 40,
          "color": "165,42,42"
        },
        {
          "type": "Line",
          "x": 330,
          "y": 250,
          "width": 20,
          "height": 0,
          "color": "0,255,0"
        },
        {
          "type": "Text",
          "text": "Resistor (330\u03a9) \u2192 LED Anode",
          "x": 230,
          "y": 280,
          "width": 300,
          "height": 25,
          "font_size": 16,
          "color": "0,255,100"
        }
      ]
    },
    {
      "step": 3,
      "description": "Wire to ESP32-C3 GPIO pin",
      "instruction": "Connect one jumper wire from the free end of the resistor to GPIO2 (or any available GPIO pin) on the ESP32-C3. This wire carries the signal voltage from the microcontroller to control the LED.",
      "visuals": [
        {
          "type": "Text",
          "text": "Step 3: Connect to GPIO2",
          "x": 50,
          "y": 50,
          "width": 400,
          "height": 40,
          "font_size": 22,
          "color": "0,200,255"
        },
        {
          "type": "Graphics",
          "filename": "esp32c3_board.svg",
          "x": 550,
